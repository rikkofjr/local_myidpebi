<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/myidpebi/db" VERSION="20260513" COMMENT="Tabel IDP EBI Lengkap">
    <TABLES>
        <TABLE NAME="local_myidpebi" COMMENT="Data Utama IDP">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="atasan_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="nama_idp" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="mulai_date" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="akhir_date" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="status" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_myidpebi_act" COMMENT="Rincian Aktivitas IDP">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="idp_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="jenis_kegiatan" TYPE="char" LENGTH="50" NOTNULL="true"/>
                <FIELD NAME="nama_activity" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="jumlah_jp" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="waktu_teks" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="evidence_fileid" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_idp" TYPE="foreign" FIELDS="idp_id" REFTABLE="local_myidpebi" REFFIELDS="id"/>
            </KEYS>
        </TABLE>
    </TABLES>
</XMLDB>